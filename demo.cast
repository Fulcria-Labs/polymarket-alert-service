[17.06654, "o", "в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\r\nStep 5: Search Polymarket for prediction markets\r\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\r\n\r\n$ curl \"http://localhost:3099/markets/search?q=trump\"\r\n"]
[17.13802, "o", "{\"query\":\"trump\",\"count\":2,\"markets\":[{\"id\":\"0x84f8b70331323c2fba97d7ceaa9a35fb645a0770d0dbff169d07f24f376766e9\",\"question\":\"Trump out as President before GTA VI?\",\"outcomes\":\"[\\\"Yes\\\", \\\"No\\\"]\",\"currentPrices\":[]},{\"id\":\"0x7b49b9bacb5f435bc10f3b100ff59e2fdd346f7f92a9001881bc9825a0af0f11\",\"question\":\"Will China invades Taiwan before GTA VI?\",\"outcomes\":\"[\\\"Yes\\\", \\\"No\\\"]\",\"currentPrices\":[]}]}\r\n\r\n"]
[19.140062, "o", "в”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\r\nStep 6: Natural language alert + x402 payment\r\nв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓв”Ѓ\r\n\r\n$ curl -X POST http://localhost:3099/alerts \\\r\n  -d {\"naturalLanguage\": \"Alert when Trump odds exceed 60%\"}\r\n\r\n"]
[19.154901, "o", "\u001b[1;39m{\r\n  \u001b[0m\u001b[1;34m\"version\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"1.0\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"network\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"base\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"chainId\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39m8453\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"payTo\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"0x8Da63b5f30e603E2D11a924C3976F67E63035cF0\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"maxAmountRequired\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"10000\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"asset\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"0x833589fCD6eDb6E08f4c7C32D4f71b54bdA02913\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"resource\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"/alerts\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"description\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"Create prediction market alert: Custom alert\"\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"expiry\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;39m1773562158\u001b[0m\u001b[1;39m,\r\n  \u001b[0m\u001b[1;34m\"nonce\"\u001b[0m\u001b[1;39m: \u001b[0m\u001b[0;32m\"0x0c8beabc5bf69c94c02f842b7bb710df\"\u001b[0m\u001b[1;39m\r\n\u001b[1;39m}\u001b[0m\r\n"]
